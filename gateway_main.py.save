import sys
import os
import time
import numpy as np
import pandas as pd
from scapy.all import sniff, IP, TCP, UDP, conf, L3RawSocket
from collections import Counter

# Ensure paths are correct
sys.path.append(os.path.dirname(os.path.abspath(__file__)))

from core.ai_engine import AIAnalyzer
from core.feature_extractor import FeatureExtractor
from core.firewall_manager import block_ip  

# Initialize
brain = AIAnalyzer()
extractor = FeatureExtractor()

# --- CONFIGURATION ---
ATTACK_THRESHOLD = 3   
# REMOVED 127.0.0.1 so you can test the attack on yourself
WHITELIST = ["10.128.0.2", "169.254.169.254"] 

attack_counter = Counter()
blocked_ips = set()
total_analyzed = 0
last_heartbeat = time.time()

def process_packet(packet):
    global total_analyzed, last_heartbeat
    
    if packet.haslayer(IP):
        src_ip = packet[IP].src
        current_time = time.time()
        
        # 1. Feature Extraction
        features = extractor.extract(packet)

        if features:
            total_analyzed += 1
            
            try:
                # 2. AI Inference
                feat_df = pd.DataFrame([features], columns=brain.feature_names)
                probs = brain.model.predict_proba(feat_df)[0]
                attack_prob = probs[1] 

                # 3. Detection Logic
                # Lowered PPS threshold to 300 for localhost testing sensitivity
                is_suspicious = (attack_prob > 0.5) or (features[6] > 300)

                if is_suspicious:
                    if src_ip not in WHITELIST and src_ip not in blocked_ips:
                        attack_counter[src_ip] += 1
                        
                        print(f"⚠️  [SUSPICIOUS] {src_ip} | AI Prob: {attack_prob:.2f} | PPS: {features[6]:.1f}")
                        print(f"   [STATS] Bytes: {features[3]} | Score: {attack_counter[src_ip]}/{ATTACK_THRESHOLD}")

                        if attack_counter[src_ip] >= ATTACK_THRESHOLD:
                            print(f"🔴 [BLOCK] DDoS Pattern Confirmed for {src_ip}")
                            block_ip(src_ip)
                            blocked_ips.add(src_ip)

            except Exception as e:
                pass # Silent during high-speed traffic to avoid console lag
            
        # Heartbeat
        if current_time - last_heartbeat > 5:
            print(f"🟢 [SYSTEM] Gateway Monitoring Active | Total Analyzed: {total_analyzed} | Blocked: {len(blocked_ips)}")
            last_heartbeat = current_time

def main():
    os.system('clear')
    print("==========================================")
    print("   AI SECURITY GATEWAY: PRODUCTION V1     ")
    print("   (Multi-Interface Monitoring)           ")
    print("==========================================")
    
    if brain.model is None:
        print("❌ FATAL: AI Model not loaded.")
        sys.exit(1)
    
    print("🛡️  Flushing Firewall Rules...")
    os.system("sudo iptables -F") 
    
    try:
        print("🚀 Monitoring Network Interfaces (All)...")
        # iface=None tells Scapy to listen on all interfaces including 'lo'
        sniff(iface=None, prn=process_packet, store=0)
    except KeyboardInterrupt:
        print("\n[!] Shutdown. Cleaning Firewall...")
        os.system("sudo iptables -F")
        sys.exit(0)

if __name__ == "__main__":
    main()
